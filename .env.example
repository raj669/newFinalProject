# ── Firebase configuration ──────────────────────────────────────────────────
#
# Copy this file to `.env` and fill in your Firebase project details.
# Never commit your real .env file to source control.
#
# Firebase Project ID (found in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Option A — Path to a downloaded service-account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

# Option B — Paste the service-account JSON directly (no file needed)
# Useful for PaaS environments like Heroku, Railway, Render, etc.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}

# ── Express server ───────────────────────────────────────────────────────────
PORT=3000
